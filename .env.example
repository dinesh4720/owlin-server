# Owlin Analytics Server Configuration
PORT=4001

# Turso Database (SQLite cloud) — get yours at https://turso.tech
TURSO_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# Admin API key for the Owlin dashboard (manages projects, views logs)
OWLIN_ADMIN_KEY=change-me-to-a-strong-secret

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:4000,http://localhost:5173,http://localhost:5174

# Environment
NODE_ENV=development
